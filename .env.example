# ---- Anthropic ----
# Your Anthropic API key. Server-side only — never exposed to the browser.
ANTHROPIC_API_KEY=sk-ant-...

# ---- Supabase ----
# Project URL (looks like https://xxxx.supabase.co)
SUPABASE_URL=https://your-project.supabase.co
# Service-role key (server-side ONLY — full DB access, never ship to client)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---- App gate ----
# Single-player passcode. Anything you type at the lock screen must match this.
APP_PASSCODE=changeme
# Secret used to sign the session cookie. Any long random string.
SESSION_SECRET=please-generate-a-long-random-string

# ---- Optional model overrides ----
# Defaults are baked into lib/anthropic.ts; override here if you want.
# DM_MODEL=claude-sonnet-5
# DM_MODEL_BIG=claude-opus-4-8
# SUMMARIZER_MODEL=claude-haiku-4-5
